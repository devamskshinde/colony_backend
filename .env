# ─── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# ─── PostgreSQL (via PgBouncer) ────────────────────────────
DB_HOST=localhost
DB_PORT=6432
DB_NAME=colony
DB_USER=colony_user
DB_PASSWORD=colony_dev_password
DB_POOL_MAX=20

# ─── Redis ─────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=colony_redis_dev

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=colony_jwt_dev_secret_at_least_32_chars_long_for_development_only
JWT_ADMIN_SECRET=colony_jwt_admin_secret_at_least_32_chars_long_for_dev_only
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d

# ─── Request Signing ───────────────────────────────────────
REQUEST_SIGNING_SECRET=colony_signing_secret_at_least_32_chars_long_for_dev
DEVICE_SECRET=colony_device_secret_at_least_32_chars_long_for_development

# ─── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_URL=amqp://colony:colony@localhost:5672

# ─── Twilio (stubbed in dev) ──────────────────────────────
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# ─── OTP (mock in dev — logs to console) ──────────────────
OTP_MOCK=true

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL=debug
