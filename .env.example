# ─── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# ─── PostgreSQL ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=6432
DB_NAME=colony
DB_USER=colony_user
DB_PASSWORD=colony_dev_password
DB_POOL_MAX=100
DB_IDLE_TIMEOUT=30000
DB_CONNECT_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=30000

# ─── Redis ─────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=colony_dev_redis
REDIS_DB=0

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=colony_jwt_secret_change_me_in_production_32chars
JWT_ADMIN_SECRET=colony_admin_secret_change_me_in_production_32
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d

# ─── Request Signing ───────────────────────────────────────
REQUEST_SIGNING_SECRET=colony_signing_secret_change_me_32chars
DEVICE_SECRET=colony_device_secret_change_me_in_production_32

# ─── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_URL=amqp://colony:colony_dev_rabbit@localhost:5672

# ─── Twilio (SMS OTP) ─────────────────────────────────────
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
OTP_MOCK=true

# ─── CORS ──────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL=debug

# ─── Admin ─────────────────────────────────────────────────
ADMIN_ALLOWED_IPS=
